{
  "name": "ai-analyst-plugin",
  "version": "2.2.0",
  "description": "AI-powered product analytics: ask a business question, get validated findings, publication-quality charts, and a slide deck.",
  "author": {
    "name": "AmarTraya",
    "email": "amarjeetsingh@traya.health",
    "url": "https://github.com/AmarTraya"
  },
  "repository": "https://github.com/AmarTraya/ai-analyst-plugin",
  "keywords": [
    "skills",
    "agent",
    "analysis",
    "collaboration",
    "question",
    "query"
  ],
  "mcpServers": {
    "knowledge": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/servers/mcp_knowledge_server.py"],
      "env": {
        "KNOWLEDGE_CACHE_DIR": "${CLAUDE_PLUGIN_DATA}/knowledge-cache",
        "KNOWLEDGE_REPO_URL": "${user_config.knowledge_repo_url}",
        "KNOWLEDGE_REPO_BRANCH": "${user_config.knowledge_repo_branch}",
        "KNOWLEDGE_LOCAL_PATH": "${user_config.knowledge_local_path}",
        "KNOWLEDGE_DATASETS": "${user_config.knowledge_datasets}",
        "KNOWLEDGE_GITHUB_TOKEN": "${user_config.knowledge_github_token}"
      }
    },
    "athena": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/servers/mcp_athena_server.py"],
      "env": {
        "AWS_PROFILE": "${user_config.aws_profile}",
        "ATHENA_DATABASE": "${user_config.athena_database}",
        "ATHENA_S3_STAGING": "${user_config.athena_s3_staging}",
        "ATHENA_REGION": "${user_config.athena_region}",
        "ATHENA_WORKGROUP": "${user_config.athena_workgroup}"
      }
    }
  },
  "userConfig": {
    "knowledge_repo_url": {
      "title": "Knowledge Repo URL",
      "description": "GitHub repo URL for knowledge base (SSH or HTTPS). Leave empty to use local path instead.",
      "type": "string",
      "sensitive": false
    },
    "knowledge_repo_branch": {
      "title": "Knowledge Repo Branch",
      "description": "Git branch to use (default: main)",
      "type": "string",
      "sensitive": false
    },
    "knowledge_local_path": {
      "title": "Knowledge Local Path",
      "description": "Local directory path to knowledge base (for testing). Used when repo URL is empty.",
      "type": "directory",
      "sensitive": false
    },
    "knowledge_datasets": {
      "title": "Dataset IDs",
      "description": "Comma-separated dataset IDs to index (e.g., traya-health). Leave empty to auto-discover from repo.",
      "type": "string",
      "sensitive": false
    },
    "knowledge_github_token": {
      "title": "GitHub Token",
      "description": "Personal access token for private knowledge repos. Leave empty for public repos or SSH.",
      "type": "string",
      "sensitive": true
    },
    "aws_profile": {
      "title": "AWS Profile",
      "description": "AWS profile name for Athena access",
      "type": "string",
      "sensitive": false
    },
    "athena_database": {
      "title": "Athena Database",
      "description": "Default Athena database (e.g., trayaprod)",
      "type": "string",
      "sensitive": false
    },
    "athena_s3_staging": {
      "title": "Athena S3 Staging",
      "description": "S3 path for Athena query results (e.g., s3://bucket/athena-output/)",
      "type": "string",
      "sensitive": false
    },
    "athena_region": {
      "title": "Athena Region",
      "description": "AWS region for Athena (e.g., ap-south-1)",
      "type": "string",
      "sensitive": false
    },
    "athena_workgroup": {
      "title": "Athena Workgroup",
      "description": "Athena workgroup (e.g., primary)",
      "type": "string",
      "sensitive": false
    }
  }
}