# Connection Template: ClickHouse
# Copy to .knowledge/datasets/{name}/manifest.yaml and fill in values.
# Requires: pip install clickhouse-connect
# Auth: username/password. Store password in env var.

dataset_id: "{dataset_id}"
display_name: "{Display Name}"
description: "{Brief description of the dataset}"
domain: "{e-commerce|saas|fintech|marketplace|other}"
created_at: "{YYYY-MM-DD}"
is_seed: false

connection:
  type: clickhouse
  host: "localhost"
  port: 8123                            # HTTP port (default 8123)
  database: "{database}"
  username: "default"
  password_env: "CLICKHOUSE_PASSWORD"   # Env var containing the password
  secure: false                         # Set true for HTTPS

summary:
  table_count: null
  total_rows: null
  date_range: null
  primary_entities: []
  key_dimensions: []
  last_profiled: null

local_data:
  path: null
  duckdb: null

status: active
last_used: null
analysis_count: 0
